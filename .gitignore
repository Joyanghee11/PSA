# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

.env*.local
.vercel
.claude/settings.local.json

# PSA_safety: temporary analysis artifacts (sources, scripts, dumps)
/tmp_analysis/

# PSA_safety: PII — members data must NEVER be committed.
# In production it is supplied via the SAFETY_MEMBERS_B64 environment variable.
# For local development place this file at src/data/safety-members.json
# (see docs/safety-deployment.md for the encoding script).
/src/data/safety-members.json
