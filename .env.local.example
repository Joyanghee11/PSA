# Claude API Key (required for article generation)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Cron secret for Vercel cron jobs (optional)
CRON_SECRET=your-cron-secret-here

# Max articles per pipeline run (optional, default: 10)
MAX_ARTICLES=10

# Admin login password (required for /admin access)
ADMIN_PASSWORD=your-admin-password-here

# JWT secret for admin session tokens (required for /admin)
JWT_SECRET=your-random-jwt-secret-here
